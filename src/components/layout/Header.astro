---
const nav = [
  {
    label: "La Scène intérieure",
    href: "/la-scene-interieure/",
    children: [
      { label: "C'est quoi ?", href: "/la-scene-interieure/" },
      { label: "La formation", href: "/la-scene-interieure-formation/" },
    ],
  },
  {
    label: "Particuliers",
    href: null,
    children: [
      { label: "Journées découverte de La Scène intérieure", href: "/la-scene-interieure-journees-decouverte/" },
      { label: "Groupe Continu de Gestalt", href: "/particuliers/groupe-continu-de-psychotherapie/" },
      { label: "Miroir du Clown", href: "/clown/" },
      { label: "Accompagnement individuel", href: "/particuliers/accompagnement-individuel/" },
    ],
  },
  {
    label: "Professionnels",
    href: null,
    children: [
      { label: "Groupe de supervision initiatique", href: "/groupe-de-supervision-initiatique/" },
      { label: "La Scène intérieure – formation", href: "/la-scene-interieure-formation/" },
    ],
  },
  {
    label: "Qui suis-je ?",
    href: "/qui-suis-je/",
    children: [
      { label: "La Gestalt-thérapie", href: "/la-gestalt-therapie/" },
      { label: "Ma déontologie", href: "/ma-deontologie/" },
      { label: "Mon parcours", href: "/qui-suis-je/" },
      { label: "Contenus en ligne", href: "/contenus-en-ligne/" },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Nicolas Cornut — Accueil">
      <img
        src="/images/logoARC.jpeg"
        alt="Nicolas Cornut"
        width="120"
        loading="eager"
      />
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      <ul class="header__nav-list">
        {nav.map((item) => (
          <li class={`header__nav-item${item.children ? ' has-dropdown' : ''}`}>
            {item.href ? (
              <a
                href={item.href}
                class={`header__nav-link${currentPath.startsWith(item.href) && item.href !== '/' ? ' is-active' : ''}`}
              >
                {item.label}
                {item.children && <span class="header__nav-arrow" aria-hidden="true">▾</span>}
              </a>
            ) : (
              <span class="header__nav-link header__nav-link--noclick">
                {item.label}
                <span class="header__nav-arrow" aria-hidden="true">▾</span>
              </span>
            )}
            {item.children && (
              <ul class="header__dropdown">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`header__dropdown-link${currentPath === child.href ? ' is-active' : ''}`}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button class="header__burger" id="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="header__mobile-nav" id="mobile-nav" aria-label="Navigation mobile" hidden>
    <ul class="header__mobile-list">
      {nav.map((item) => (
        <li class="header__mobile-item">
          {item.href ? (
            <a href={item.href} class="header__mobile-link">{item.label}</a>
          ) : (
            <span class="header__mobile-link header__mobile-link--noclick">{item.label}</span>
          )}
          {item.children && (
            <ul class="header__mobile-sub">
              {item.children.map((child) => (
                <li><a href={child.href} class="header__mobile-sublink">{child.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .header__inner {
    max-width: var(--max-width-container);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 90px;
  }

  .header__logo img {
    height: 70px;
    width: auto;
    display: block;
  }

  .header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 28px 14px;
    font-family: var(--font-nav);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #333;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    cursor: pointer;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: var(--color-primary);
    text-decoration: none;
  }

  .header__nav-link--noclick {
    cursor: default;
  }

  .header__nav-arrow {
    font-size: 10px;
    transition: transform 0.2s;
  }

  .header__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 260px;
    background: white;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    list-style: none;
    padding: 8px 0;
    margin: 0;
    z-index: 100;
  }

  .has-dropdown:hover .header__dropdown {
    display: block;
  }

  .has-dropdown:hover .header__nav-arrow {
    transform: rotate(180deg);
  }

  .header__dropdown-link {
    display: block;
    padding: 10px 20px;
    font-family: var(--font-body); /* Open Sans */
    font-size: 13px;
    color: #444;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .header__dropdown-link:hover,
  .header__dropdown-link.is-active {
    color: var(--color-primary);
    background: #fafafa;
    text-decoration: none;
  }

  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #333;
    transition: all 0.3s;
  }

  .header__mobile-nav {
    background: white;
    border-top: 1px solid var(--color-border);
    padding: 16px 24px;
  }

  .header__mobile-nav[hidden] { display: none; }

  .header__mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__mobile-link {
    display: block;
    padding: 12px 0;
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    color: #333;
    text-decoration: none;
    border-bottom: 1px solid #f0f0f0;
  }

  .header__mobile-link--noclick {
    cursor: default;
    color: #888;
  }

  .header__mobile-sub {
    list-style: none;
    margin: 0;
    padding: 0 0 0 16px;
  }

  .header__mobile-sublink {
    display: block;
    padding: 8px 0;
    font-size: 13px;
    color: #555;
    text-decoration: none;
  }

  .header__mobile-link:hover,
  .header__mobile-sublink:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  /* Espacement body pour header fixe */
  :global(body) {
    padding-top: 90px;
  }

  @media (max-width: 1024px) {
    .header__nav { display: none; }
    .header__burger { display: flex; }
  }

  @media (min-width: 1025px) {
    .header__mobile-nav { display: none !important; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (isOpen) {
      mobileNav?.setAttribute('hidden', '');
    } else {
      mobileNav?.removeAttribute('hidden');
    }
  });
</script>
