---
export const prerender = false;
import datesData from '../../data/dates.json';

const sections = [
  {
    key: 'groupe_continu',
    label: 'Groupe Continu Psychothérapeutique',
    url: '/particuliers/groupe-continu-de-psychotherapie/',
    data: datesData.groupe_continu,
  },
  {
    key: 'supervision',
    label: 'Groupe de supervision',
    url: '/groupe-de-supervision-initiatique/',
    data: datesData.supervision,
  },
  {
    key: 'journee_decouverte',
    label: 'La Scène intérieure – Journée découverte',
    url: '/la-scene-interieure-journees-decouverte/',
    data: datesData.journee_decouverte,
  },
  {
    key: 'scene_interieure_formation',
    label: 'La Scène intérieure – Formation',
    url: '/la-scene-interieure-formation/',
    data: datesData.scene_interieure_formation,
  },
];
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Back office — Dates</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Open Sans', sans-serif; font-size: 15px; background: #f5f5f5; color: #333; margin: 0; padding: 0; }

    .admin-header {
      background: #580213;
      color: white;
      padding: 20px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .admin-header h1 { margin: 0; font-size: 1.2rem; font-weight: 700; letter-spacing: .03em; }
    .admin-header a { color: rgba(255,255,255,0.7); font-size: 13px; text-decoration: none; }
    .admin-header a:hover { color: white; }

    .admin-body { max-width: 860px; margin: 40px auto; padding: 0 24px 80px; }

    .notice {
      background: #fff8e1;
      border-left: 3px solid #f0a500;
      padding: 12px 16px;
      margin-bottom: 32px;
      font-size: 13px;
      color: #555;
    }

    .section-card {
      background: white;
      border-radius: 4px;
      box-shadow: 0 1px 6px rgba(0,0,0,.08);
      margin-bottom: 32px;
      overflow: hidden;
    }
    .section-card__header {
      background: #fafafa;
      border-bottom: 1px solid #eee;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-card__header h2 {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      color: #333;
    }
    .section-card__header a {
      font-size: 12px;
      color: #580213;
      text-decoration: none;
    }
    .section-card__header a:hover { text-decoration: underline; }
    .section-card__body { padding: 24px; }

    .dates-list { list-style: none; margin: 0 0 16px; padding: 0; }
    .dates-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 8px;
    }
    .dates-list li textarea {
      flex: 1;
      border: 1px solid #ddd;
      border-radius: 3px;
      padding: 8px 12px;
      font-family: inherit;
      font-size: 14px;
      color: #333;
      transition: border-color .2s;
      resize: none;
      overflow: hidden;
      min-height: 38px;
      line-height: 1.5;
    }
    .dates-list li textarea:focus {
      outline: none;
      border-color: #580213;
    }
    .btn-remove {
      background: none;
      border: 1px solid #ddd;
      border-radius: 3px;
      width: 30px;
      height: 30px;
      cursor: pointer;
      color: #aaa;
      font-size: 16px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s;
      flex-shrink: 0;
    }
    .btn-remove:hover { border-color: #c0392b; color: #c0392b; background: #fff5f5; }

    .btn-add {
      background: none;
      border: 1px dashed #ccc;
      border-radius: 3px;
      padding: 7px 14px;
      font-family: inherit;
      font-size: 13px;
      color: #888;
      cursor: pointer;
      width: 100%;
      text-align: left;
      transition: all .2s;
    }
    .btn-add:hover { border-color: #580213; color: #580213; background: #fff8f8; }

    .section-footer {
      padding: 16px 24px;
      border-top: 1px solid #f0f0f0;
      display: flex;
      justify-content: flex-end;
    }
    .btn-save {
      background: #580213;
      color: white;
      border: none;
      border-radius: 3px;
      padding: 10px 24px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s;
    }
    .btn-save:hover { background: #3d0109; }
    .btn-save:disabled { background: #aaa; cursor: not-allowed; }

    .toast {
      position: fixed;
      bottom: 32px;
      right: 32px;
      background: #2d6a4f;
      color: white;
      padding: 12px 20px;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 600;
      opacity: 0;
      transform: translateY(10px);
      transition: all .3s;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.error { background: #c0392b; }
  </style>
</head>
<body>

<header class="admin-header">
  <h1>⚙️ Back office — Gestion des dates</h1>
  <a href="/" target="_blank">← Voir le site</a>
</header>

<div class="admin-body">
  <div class="notice">
    ℹ️ En cliquant sur "Enregistrer", les dates sont commitées sur GitHub et le site se met à jour automatiquement en <strong>~1 minute</strong>.
  </div>

  {sections.map((section) => (
    <div class="section-card" data-key={section.key}>
      <div class="section-card__header">
        <h2>{section.label}</h2>
        <a href={section.url} target="_blank">Voir la page →</a>
      </div>
      <div class="section-card__body">
        <ul class="dates-list">
          {section.data.dates.map((date) => (
            <li>
              <textarea placeholder="Ex: Vendredi 10 avril – Journée à Paris" rows={1}>{date}</textarea>
              <button class="btn-remove" title="Supprimer">×</button>
            </li>
          ))}
          {section.data.dates.length === 0 && (
            <li>
              <textarea placeholder="Ex: Vendredi 10 avril – Journée à Paris" rows={1}></textarea>
              <button class="btn-remove" title="Supprimer">×</button>
            </li>
          )}
        </ul>
        <button class="btn-add" data-section={section.key}>+ Ajouter une date</button>
      </div>
      <div class="section-footer">
        <button class="btn-save" data-section={section.key}>Enregistrer</button>
      </div>
    </div>
  ))}
</div>

<div class="toast" id="toast"></div>

<script>
  function autoResize(el: HTMLTextAreaElement) {
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }

  // Auto-resize au chargement et à la saisie
  document.querySelectorAll<HTMLTextAreaElement>('.dates-list textarea').forEach(ta => {
    autoResize(ta);
    ta.addEventListener('input', () => autoResize(ta));
  });

  function showToast(msg: string, error = false) {
    const t = document.getElementById('toast')!;
    t.textContent = msg;
    t.className = 'toast show' + (error ? ' error' : '');
    setTimeout(() => t.className = 'toast', 2800);
  }

  function makeRow(value = '') {
    const li = document.createElement('li');
    li.innerHTML = `<textarea placeholder="Ex: Vendredi 10 avril – Journée à Paris" rows="1">${value}</textarea><button class="btn-remove" title="Supprimer">×</button>`;
    const ta = li.querySelector('textarea') as HTMLTextAreaElement;
    ta.addEventListener('input', () => autoResize(ta));
    li.querySelector('.btn-remove')!.addEventListener('click', () => li.remove());
    return li;
  }

  // Ajouter une ligne
  document.querySelectorAll('.btn-add').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.section-card')!;
      const list = card.querySelector('.dates-list')!;
      const li = makeRow();
      list.appendChild(li);
      const ta = li.querySelector('textarea') as HTMLTextAreaElement;
      ta.focus();
      autoResize(ta);
    });
  });

  // Supprimer une ligne (existantes)
  document.querySelectorAll('.btn-remove').forEach(btn => {
    btn.addEventListener('click', () => btn.closest('li')!.remove());
  });

  // Enregistrer
  document.querySelectorAll('.btn-save').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = (btn as HTMLElement).dataset.section!;
      const card = document.querySelector(`.section-card[data-key="${key}"]`)!;
      const textareas = card.querySelectorAll('textarea') as NodeListOf<HTMLTextAreaElement>;
      const dates = Array.from(textareas).map(t => t.value.trim()).filter(Boolean);

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = 'Enregistrement…';

      try {
        const res = await fetch('/api/update-dates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ [key]: dates }),
        });
        const data = await res.json();
        if (data.ok) {
          showToast('✅ Dates enregistrées !');
        } else {
          showToast('❌ Erreur : ' + data.error, true);
        }
      } catch (e) {
        showToast('❌ Erreur réseau', true);
      }

      (btn as HTMLButtonElement).disabled = false;
      (btn as HTMLButtonElement).textContent = 'Enregistrer';
    });
  });
</script>

</body>
</html>
